{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "ziloteams-api-test",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "CHANNELS", "class_name": "ChannelRoom" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ChannelRoom"] }
  ]
}
